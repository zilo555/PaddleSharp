+namespace paddle_infer {
+namespace capi_exp {
+
+namespace {
+thread_local int g_last_error_code = PD_STATUS_OK;
+thread_local std::string g_last_error_message;
+}  // namespace
+
+void ClearLastError() {
+  g_last_error_code = PD_STATUS_OK;
+  g_last_error_message.clear();
+}
+
+int GetLastErrorCode() { return g_last_error_code; }
+
+const char* GetLastErrorMessage() { return g_last_error_message.c_str(); }
+
+int SetLastError(PD_StatusCode code, const std::string& message) {
+  g_last_error_code = code;
+  g_last_error_message = message;
+  return code;
+}
+
+}  // namespace capi_exp
+}  // namespace paddle_infer
+
+extern "C" {
+
+int PD_GetLastErrorCode() {
+  return paddle_infer::capi_exp::GetLastErrorCode();
+}
+
+const char* PD_GetLastError() {
+  return paddle_infer::capi_exp::GetLastErrorMessage();
+}
+
+}  // extern "C"
