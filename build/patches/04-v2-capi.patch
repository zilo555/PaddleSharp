+#pragma once
+
+#include <exception>
+#include <stdexcept>
+#include <string>
+#include <utility>
+
+#include "paddle/fluid/inference/capi_exp/pd_common.h"
+#include "paddle/fluid/platform/enforce.h"
+
+namespace paddle_infer {
+namespace capi_exp {
+
+void ClearLastError();
+int GetLastErrorCode();
+const char* GetLastErrorMessage();
+int SetLastError(PD_StatusCode code, const std::string& message);
+
+template <typename Func>
+int SafeCall(Func&& func) noexcept {
+  try {
+    ClearLastError();
+    std::forward<Func>(func)();
+    return PD_STATUS_OK;
+  } catch (const common::enforce::EnforceNotMet& exception) {
+    return SetLastError(PD_STATUS_PADDLE_EXCEPTION, exception.what());
+  } catch (const std::invalid_argument& exception) {
+    return SetLastError(PD_STATUS_INVALID_ARGUMENT, exception.what());
+  } catch (const std::exception& exception) {
+    return SetLastError(PD_STATUS_STD_EXCEPTION, exception.what());
+  } catch (...) {
+    return SetLastError(PD_STATUS_UNKNOWN, "Unknown C++ exception");
+  }
+}
+
+template <typename T, typename Func>
+int SafeCallWithOutput(T* out, T failure_value, Func&& func) noexcept {
+  if (out != nullptr) {
+    *out = failure_value;
+  }
+  if (out == nullptr) {
+    return SetLastError(PD_STATUS_INVALID_ARGUMENT,
+                        "The pointer of out shouldn't be nullptr");
+  }
+  return SafeCall([&]() { *out = std::forward<Func>(func)(); });
+}
+
+}  // namespace capi_exp
+}  // namespace paddle_infer
