+if(ON_INFER AND NOT WITH_PYTHON)
+  # Inference-only builds do not need backward kernels.
+  set(infer_grad_kernel_cu)
+  foreach(kernel IN LISTS kernel_cu)
+    if(kernel MATCHES "grad")
+      list(APPEND infer_grad_kernel_cu "${kernel}")
+    endif()
+  endforeach()
+
+  set(infer_grad_kernel_gpu)
+  foreach(kernel IN LISTS kernel_gpu)
+    if(kernel MATCHES "grad")
+      list(APPEND infer_grad_kernel_gpu "${kernel}")
+    endif()
+  endforeach()
+
+  set(infer_grad_kernel_cc)
+  foreach(kernel IN LISTS kernel_cc)
+    if(kernel MATCHES "grad")
+      list(APPEND infer_grad_kernel_cc "${kernel}")
+    endif()
+  endforeach()
+
+  if(infer_grad_kernel_cu)
+    list(REMOVE_ITEM kernel_cu ${infer_grad_kernel_cu})
+  endif()
+  if(infer_grad_kernel_gpu)
+    list(REMOVE_ITEM kernel_gpu ${infer_grad_kernel_gpu})
+  endif()
+  if(infer_grad_kernel_cc)
+    list(REMOVE_ITEM kernel_cc ${infer_grad_kernel_cc})
+  endif()
+endif()
